# Required Netlify environment variables for StarshipWatch.
# Copy this to .env (gitignored) for local dev, or set these in
# Netlify → Site config → Environment variables for production.

# Public Supabase project URL (safe to expose to the browser).
SUPABASE_URL=https://your-project.supabase.co

# Public anon key — readable by the browser. Security depends on
# Row Level Security policies in Supabase, NOT on this key being secret.
SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key — server-only. NEVER expose to the browser.
# Used by netlify/functions/sync-launches.js to write the flights table.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
